{
  "name": "DigitalOutput",
  "version": "0.1.0",
  "description": "A lightweight, multi-platform, thread-safe, and glitch-free digital output (relay, LED, valve) control library for Arduino. Seamlessly mixes local GPIOs and MCP23X17 expanders via polymorphism.",
