    "relay",
    "digital-output",
    "mcp23017",
    "mcp23x17",
    "thread-safe",
    "freertos",
    "glitch-free",
    "pulse",
    "non-blocking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/soosp/DigitalOutput"
  },
  "authors": [
    {
      "name": "Péter Soós",
      "maintainer": true
    }
  ],
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org"
    }
  ],
  "frameworks": "arduino",
  "platforms": "*",
  "dependencies": {
    "adafruit/Adafruit MCP23017 Arduino Library": "^2.3.0"
  }
}
